# =============================================================================
# NYAYA PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values before running locally.
# NEVER commit .env to version control.
# =============================================================================

# --- Environment ---
ENVIRONMENT=development
# Options: development | staging | production

# --- Database ---
DATABASE_URL=postgresql+asyncpg://nyaya:nyaya_secret@localhost:5432/nyaya_db
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
# Comma-separated list for multiple brokers: localhost:9092,localhost:9093

# Kafka Topics
KAFKA_TOPIC_RAW_ARTICLES=nyaya.raw_articles
KAFKA_TOPIC_SANITIZED_ARTICLES=nyaya.sanitized_articles
KAFKA_TOPIC_EXTRACTED_EVENTS=nyaya.extracted_events
KAFKA_TOPIC_RESOLVED_EVENTS=nyaya.resolved_events
KAFKA_TOPIC_LOW_CONFIDENCE=nyaya.low_confidence_extractions

# --- OpenSearch ---
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=nyaya-raw-articles
MINIO_BUCKET_SANITIZED=nyaya-sanitized-articles
# Set to "true" if MinIO is running over TLS
MINIO_USE_TLS=false

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...   # required for pgvector embeddings (text-embedding-004)

# --- JWT Authentication ---
# Paths to RSA key files (generate with: openssl genrsa -out private.pem 4096)
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# --- Privacy ---
# 32-byte hex string used as HMAC salt for victim pseudonym generation
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
PRIVACY_SALT=replace_with_64_hex_chars_generated_by_secrets_token_hex_32

# --- Observability ---
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- API (Next.js public) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- API Rate Limiting ---
# Requests per minute
API_RATE_LIMIT_PUBLIC=60
API_RATE_LIMIT_API_KEY=1000

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Logging ---
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
