{
  "title": "Nyaya — API",
  "uid": "nyaya-api",
  "tags": ["nyaya", "api"],
  "timezone": "Asia/Kolkata",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job='nyaya-api'}[5m])) by (method, route)",
        "legendFormat": "{{method}} {{route}}"
      }]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job='nyaya-api', status=~'5..'}[5m]))",
        "legendFormat": "5xx/s"
      }]
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job='nyaya-api'}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job='nyaya-api'}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job='nyaya-api'}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Rate Limit Hits",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{
        "expr": "rate(nyaya_rate_limit_exceeded_total[5m])",
        "legendFormat": "Rate limit hits/s"
      }]
    },
    {
      "id": 5,
      "title": "Active Connections",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
      "targets": [{
        "expr": "nyaya_active_connections",
        "legendFormat": "Connections"
      }]
    },
    {
      "id": 6,
      "title": "Moderation Queue Depth",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
      "targets": [{
        "expr": "nyaya_moderation_queue_depth",
        "legendFormat": "Pending"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38
}
